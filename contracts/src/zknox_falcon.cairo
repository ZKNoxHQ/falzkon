//! Implementation of Number Theoretic Transform (NTT) based on ZKNOX implementation

use crate::zknox_ntt::{zknox_nttInv, zknox_nttFW, reduc256};
use crate::zknox_hashToPoint::HashToPoint_RIP;
use crate::blake2s_hash::HashToPoint_Blake2s;


pub const Q64: i64 = 12289;
pub const Q252: felt252 = 12289;

pub const n: usize=512;
pub const qs1:i64 = 6144; // q >> 1;
pub const sigBound:i64 = 34034726;


//reduce mod Q via 256 bit words
pub fn reduc64(a: felt252)-> i64 {
    let a64: i64 = a.try_into().unwrap();
    let res = (a64 % Q64).try_into().unwrap();

    return res;
}


//multiplication where the right operator is already in ntt representation (example: public key ntt precomputed for once)
//todo: use unreduced to avoid modular reductions
fn zknox_nttHalfMul(mut a: Span<felt252>, mut ntt_b: Span<felt252>) ->Span<felt252>{
    let mut tmp=array![];

    let mut ntt_a=zknox_nttFW(a);
    let mut i=0;
    while(i!=n){
        tmp.append(reduc256(*ntt_a[i]* *ntt_b[i]));

        i=i+1;
    }

    return zknox_nttInv(tmp.span());
}

//return a reduced i32 span
fn zknox_subvec(mut hashed: Span<felt252>, mut s1pk: Span<felt252>)->Span<i64>{
    let mut tmp=array![];
    let mut i=0;

    while(i!=n){
        tmp.append(reduc64( (*hashed[i])+Q252 - (*s1pk[i])));//hash-s1.pk

        i=i+1;
    }

    return tmp.span();
}

fn zknox_falcon_normalize(mut s0: Span<i64>, mut s1: Span<felt252>) -> bool{

    let mut i=0;
    let mut norm:i64=0;

    while i!=512{
        let mut tmp:i64=(*s1[i]).try_into().unwrap();
      

        if tmp>qs1 {
            //norm=norm+(Q64-tmp)*(Q64-tmp);
        }
        else{
            //norm=norm+(tmp*tmp);
        }
        tmp=*s0[i];
       

        if tmp>qs1 {
            norm=norm+(Q64-tmp)*(Q64-tmp);
        }
        else{
            norm=norm+(tmp*tmp);
        }
        i=i+1;
    }
    if norm > sigBound{
        return false;//todo replace
    }
    return true;
}


//s2: 512 felts of value <12289 representing the s2 part of falcon signature
//nttpk: 512 felts of value <12289 representing the public key in ntt representation
//result of hashToPoint(signature.salt, msgs, q, n);
pub fn zknox_falcon_core(mut s1: Span<felt252>, mut nttpk: Span<felt252>, mut hashed: Span<felt252>) -> bool {
   
    let mut s1pk=zknox_nttHalfMul(s1, nttpk);
    let mut s0=zknox_subvec(hashed, s1pk);//s0=hashed-s1pk 

    let mut res:bool=zknox_falcon_normalize(s0,s1);
    
    return res;
}


pub fn zknox_ethfalcon_verify( txhigh:felt252, txlow:felt252, salt_high:felt252, salt_low:felt252,
    mut s1: Span<felt252>, mut nttpk: Span<felt252> )->bool{
    // hash computation
    let mut hash=HashToPoint_RIP(txhigh, txlow, salt_high, salt_low);
    // falcon core verification
    let res=zknox_falcon_core(s1, nttpk, hash);
    return res;

}

//zk friendly version using blake2s
pub fn zknox_falzkon_verify( salt: ByteArray, msgHash: ByteArray,
    mut s1: Span<felt252>, mut nttpk: Span<felt252> )->bool{

    //todo: control parameters
    let mut hashed =HashToPoint_Blake2s(msgHash, salt);
    let res=zknox_falcon_core(s1, nttpk, hashed);

    return res;
}


