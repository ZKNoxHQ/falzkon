//reduce mod Q via 256 bit words
fn reduc256(a: felt252)-> felt252 {
    let a256: u256 = a.into();
    let res = (a256 % Q256).try_into().unwrap();

    return res;
}

fn red256(mut a: Span<felt252>) -> Span<felt252> {
    let mut tmp=array![];
    let mut i=0;

    while i!=512{
        tmp.append(reduc256(*a.pop_front().unwrap()));
        i=i+1;
    }

    return tmp.span();
}



