pub const Q: felt252 = 12289;

pub const Q128: u128 = 12289;
pub const Q256: u256 = 12289;

pub const n: usize = 512;

// Modular addition: (a + b) mod p
fn addmod(a: felt252, b: felt252) -> felt252 {
    let sum = a + b;
    let sum_u256: u256 = sum.into();
   
    if sum_u256 >= 12289 {
        return sum - 12289;
    } else {
        return sum;
    }
}

// Modular subtraction: (a - b) mod p  
fn submod(a: felt252, b: felt252) -> felt252 {
    let sum = (12289 + a - b);
    let sum_u256: u256 = sum.into();
   
    if sum_u256 >= 12289 {
        return sum - 12289;
    } else {
        return sum;
    }
}

// Modular multiplication: (a * b) mod p
fn mulmod(a: felt252, b: felt252) -> felt252 {
    let product = a * b;
    let prod256: u256 = product.into();
    let res = (prod256 % 12289).try_into().unwrap();
    return res;
}



fn reorder(mut low: Array<felt252>, mut high: Array<felt252>) -> Span<felt252> {
    let mut i=0;
    let mut tmp=array![];
    
    while i!=256 {
        tmp.append( low.pop_front().unwrap());
        //tmp.append( *low[i]);//slower
        
        i=i+1;
    }
    while i!=512{
        tmp.append( high.pop_front().unwrap());//better than tmp.append( *high[i-256]);
        i=i+1;
    }
   
    return tmp.span();
}


fn reorder2(mut low: Array<felt252>, mut high: Array<felt252>, mut t:usize) -> Span<felt252> {
    let mut i=0;
    let mut tmp=array![];
    let mut cpt=0;


    while i!=512{
       cpt=0;
        while cpt !=t{
            tmp.append( low.pop_front().unwrap());
            cpt=cpt+1;
        }
        cpt=0;
        while cpt!=t{
            tmp.append( high.pop_front().unwrap());//better than tmp.append( *high[i-256]);
            cpt=cpt+1;
        }
        i=i+2*t;
    }

    return tmp.span();
}


